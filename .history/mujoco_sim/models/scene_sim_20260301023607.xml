<!--
  SO-ARM100 Enhanced Scene for Simulation
  Extends official model with sensors, target marker, and table
-->
<mujoco model="so_arm100_sim">
  <include file="trs_so_arm100/so_arm100.xml"/>

  <statistic center="0.1 -0.15 0.1" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="target_mat" rgba="1 0.2 0.2 0.6"/>
    <material name="object_mat" rgba="0.2 0.8 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light pos="0.5 -0.5 1.0" dir="-0.3 0.3 -1" directional="false" diffuse="0.4 0.4 0.4"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Target visualization sphere (no collision) -->
    <body name="target" pos="0 -0.25 0.15" mocap="true">
      <geom name="target_geom" type="sphere" size="0.012" material="target_mat"
            contype="0" conaffinity="0" group="2"/>
    </body>

    <!-- Small cube object for manipulation demo -->
    <body name="cube" pos="0.05 -0.30 0.015">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.015 0.015 0.015" mass="0.02"
            material="object_mat" friction="1.0 0.005 0.0001"/>
    </body>
  </worldbody>

  <!-- Sensors for reading arm state -->
  <sensor>
    <!-- Joint positions -->
    <jointpos name="pos_Rotation" joint="Rotation"/>
    <jointpos name="pos_Pitch" joint="Pitch"/>
    <jointpos name="pos_Elbow" joint="Elbow"/>
    <jointpos name="pos_Wrist_Pitch" joint="Wrist_Pitch"/>
    <jointpos name="pos_Wrist_Roll" joint="Wrist_Roll"/>
    <jointpos name="pos_Jaw" joint="Jaw"/>
    <!-- Joint velocities -->
    <jointvel name="vel_Rotation" joint="Rotation"/>
    <jointvel name="vel_Pitch" joint="Pitch"/>
    <jointvel name="vel_Elbow" joint="Elbow"/>
    <jointvel name="vel_Wrist_Pitch" joint="Wrist_Pitch"/>
    <jointvel name="vel_Wrist_Roll" joint="Wrist_Roll"/>
    <jointvel name="vel_Jaw" joint="Jaw"/>
    <!-- End-effector (Fixed_Jaw body frame) -->
    <framepos name="ee_pos" objtype="xbody" objname="Fixed_Jaw"/>
    <framequat name="ee_quat" objtype="xbody" objname="Fixed_Jaw"/>
  </sensor>
</mujoco>
